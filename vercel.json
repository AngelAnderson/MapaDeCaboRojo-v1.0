
{
  "crons": [
    {
      "path": "/api/cron?job=briefing",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron?job=maintenance",
      "schedule": "0 3 * * 1"
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/municipio", "destination": "/api/pages?page=municipio" },
    { "source": "/turismo", "destination": "/api/pages?page=turismo" },
    { "source": "/demanda", "destination": "/api/pages?page=demanda" },
    { "source": "/api/intelligence", "destination": "/api/pages?page=intelligence" },
    { "source": "/negocio/:slug", "destination": "/api/negocio?slug=:slug" },
    { "source": "/farmacia/:slug", "destination": "/api/farmacia?slug=:slug&type=farmacia" },
    { "source": "/dentista/:slug", "destination": "/api/farmacia?slug=:slug&type=dentista" },
    { "source": "/veterinario/:slug", "destination": "/api/farmacia?slug=:slug&type=veterinario" },
    { "source": "/medico/:slug", "destination": "/api/farmacia?slug=:slug&type=medico" },
    { "source": "/hospital/:slug", "destination": "/api/farmacia?slug=:slug&type=hospital" },
    { "source": "/laboratorio/:slug", "destination": "/api/farmacia?slug=:slug&type=laboratorio" },
    { "source": "/optica/:slug", "destination": "/api/farmacia?slug=:slug&type=optica" },
    { "source": "/salud-mental/:slug", "destination": "/api/farmacia?slug=:slug&type=salud-mental" },
    { "source": "/quiropractico/:slug", "destination": "/api/farmacia?slug=:slug&type=quiropractico" },
    { "source": "/gimnasio/:slug", "destination": "/api/farmacia?slug=:slug&type=gimnasio" },
    { "source": "/categoria/:cat", "destination": "/api/categoria?cat=:cat" },
    { "source": "/llms.txt", "destination": "/api/public?action=llms" },
    { "source": "/llms-full.txt", "destination": "/api/public?action=llms-full" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.ts": {
      "maxDuration": 60
    }
  }
}
